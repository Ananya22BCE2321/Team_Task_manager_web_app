{
  "name": "team-task-manager",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently \"npm --workspace server run dev\" \"npm --workspace client run dev\"",
    "start": "npm --workspace server start",
    "build": "npm --workspace client build",
    "postinstall": "npm --workspace client run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
